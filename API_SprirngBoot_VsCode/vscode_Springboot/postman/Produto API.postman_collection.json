{
  "info": {
    "name": "Produto API - Demo",
    "description": "Coleção Postman com exemplos para os 11 endpoints da API de Produtos (porta 8088).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Listar todos os produtos",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "{{accept}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos"]
        }
      }
    },
    {
      "name": "Listar produtos ativos",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "{{accept}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/ativos",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "ativos"]
        }
      }
    },
    {
      "name": "Buscar produto por ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "{{accept}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/{{productId}}",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "{{productId}}"]
        }
      }
    },
    {
      "name": "Buscar produto por SKU",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "{{accept}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/sku/{{productSku}}",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "sku", "{{productSku}}"]
        }
      }
    },
    {
      "name": "Buscar por nome (query)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "{{accept}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/buscar?nome={{productName}}",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "buscar"],
          "query": [
            {
              "key": "nome",
              "value": "{{productName}}"
            }
          ]
        }
      }
    },
    {
      "name": "Criar produto",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "{{contentType}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"{{newProductName}}\",\n  \"descricao\": \"{{newProductDescription}}\",\n  \"preco\": {{newProductPrice}},\n  \"quantidade\": {{newProductQuantity}},\n  \"sku\": \"{{newProductSku}}\",\n  \"ativo\": true\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos"]
        }
      }
    },
    {
      "name": "Atualizar produto (PUT)",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "{{contentType}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{productId}},\n  \"nome\": \"{{newProductName}}\",\n  \"descricao\": \"{{newProductDescription}}\",\n  \"preco\": {{newProductPrice}},\n  \"quantidade\": {{newProductQuantity}},\n  \"sku\": \"{{newProductSku}}\",\n  \"ativo\": true\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/{{productId}}",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "{{productId}}"]
        }
      }
    },
    {
      "name": "Deletar produto",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/{{productId}}",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "{{productId}}"]
        }
      }
    },
    {
      "name": "Desativar produto (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/{{productId}}/desativar",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "{{productId}}", "desativar"]
        }
      }
    },
    {
      "name": "Ativar produto (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/{{productId}}/ativar",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "{{productId}}", "ativar"]
        }
      }
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "{{accept}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}{{apiPath}}/health",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "produtos", "health"]
        }
      },
      "response": [
        {
          "name": "Exemplo de response",
          "originalRequest": {},
          "status": "OK",
          "code": 200,
          "_body": "{\n  \"status\": \"UP\",\n  \"mensagem\": \"API de Produtos está rodando\"\n}",
          "header": []
        }
      ]
    }
  ]
}
